<div class="relative overflow-hidden rounded-lg bg-slate-800 px-4 pb-5 pt-5 shadow">
    <div>
        <div class="absolute rounded-md p-3 text-white bg-indigo-500">
            <div class="h-6 w-6 flex justify-center items-center">
                @DegreeC
            </div>
        </div>
        <p class="ml-16 truncate text-sm font-medium text-slate-500">
            @Location
        </p>
    </div>

    <div class="ml-16 flex items-baseline">
        <p class="text-2xl text-white">
            @Description
        </p>
    </div>
</div>

@code
{
    [Parameter] public int DegreeC { get; set; }
    [Parameter] public string Description { get; set; }
    [Parameter] public string Location { get; set; }
}
